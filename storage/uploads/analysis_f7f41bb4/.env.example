# 🧠 Adaptive AI Story Engine - Environment Configurations

# 1. Google Gemini API Key (Required)
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Database URI (Optional - For Phase 3/4 MongoDB Persistent Saves)
# Default is your local MongoDB instance. Uncomment database connections in storage/database.py to activate.
MONGO_URI=mongodb://localhost:27017/
